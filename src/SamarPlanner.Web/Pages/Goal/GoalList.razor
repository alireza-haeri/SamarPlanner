@page "/goals"
@attribute [Authorize]
@layout GoalLayout
@inject IApiClient ApiClient
@inject IToastService ToastService
@inject IApiService ApiService
@inject NavigationManager NavigationManager

<div class="goals-page">
    <div class="page-header">
        <h3>🎯 همه اهداف</h3>
        <span class="text-muted small">@_totalCount هدف</span>
    </div>

    @if (_isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-success" role="status"></div>
            <span>بارگذاری...</span>
        </div>
    }
    else if (_goals == null || !_goals.Any())
    {
        <div class="empty-state">
            <i class="bi bi-bullseye"></i>
            <h4>هیچ هدفی تعریف نکرده‌اید</h4>
            <p class="text-muted">برای شروع، یک هدف جدید ایجاد کنید.</p>
        </div>
    }
    else
    {
        <div class="goals-tree">
            @foreach (var goal in _goals)
            {
                <GoalItem Goal="@goal" OnGoalUpdated="LoadGoals" />
            }
        </div>
    }
</div>

@code {
    private List<GetAllGoalsByUserIdQueryResponseGoals>? _goals;
    private bool _isLoading = true;
    private int _totalCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadGoals();
    }

    private async Task LoadGoals()
    {
        try
        {
            _isLoading = true;
            var result = await ApiService.SendAsync(
                () => ApiClient.GetGoalsAsync(),
                successMessage: null,
                showErrorToast: true
            );

            if (result?.IsSuccess == true)
            {
                _goals = result.Response?.Goals?.ToList() ?? new List<GetAllGoalsByUserIdQueryResponseGoals>();
                _totalCount = CountGoals(_goals);
            }
            else
            {
                _goals = new List<GetAllGoalsByUserIdQueryResponseGoals>();
                _totalCount = 0;
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowToastError($"خطا: {ex.Message}");
            _goals = new List<GetAllGoalsByUserIdQueryResponseGoals>();
            _totalCount = 0;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private int CountGoals(List<GetAllGoalsByUserIdQueryResponseGoals>? goals)
    {
        if (goals == null) return 0;
        var count = goals.Count;
        foreach (var goal in goals)
        {
            count += CountGoals(goal.Goals?.ToList());
        }
        return count;
    }
}