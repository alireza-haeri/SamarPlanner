@page "/tasks/deleted"
@using System.Globalization
@using SamarPlanner.Web.Helpers
@attribute [Authorize]
@layout TaskLayout
@inject IApiClient ApiClient
@inject IToastService ToastService
@inject IApiService ApiService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<ModalPortal />

<div class="deleted-tasks">

    @* ── Header ── *@
    <div class="deleted-header">
        <div class="deleted-header-left">
            <h1 class="deleted-title">تسک‌های حذف شده</h1>
            <span class="deleted-subtitle">تسک‌هایی که قبلاً حذف کرده‌اید</span>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="deleted-loading">
            <div class="deleted-loading-spinner"></div>
            <span>بارگذاری...</span>
        </div>
    }
    else if (_tasks == null || !_tasks.Any())
    {
        <div class="deleted-empty">
            <div class="deleted-empty-icon">
                <i class="bi bi-trash3"></i>
            </div>
            <h3>هیچ تسک حذف شده‌ای وجود ندارد</h3>
            <p>تسک‌هایی که حذف می‌کنید در اینجا ظاهر می‌شوند</p>
        </div>
    }
    else
    {
        <div class="deleted-list">
            @foreach (var task in _tasks)
            {
                <div class="deleted-item">
                    <div class="deleted-item-icon">
                        <i class="bi bi-trash3"></i>
                    </div>
                    <div class="deleted-item-body">
                        <span class="deleted-item-title">@task.Title</span>
                    </div>
                    <div class="deleted-item-actions">
                        <button class="deleted-action-btn deleted-action-restore"
                                @onclick="() => RestoreTask(task.TaskId)"
                                title="بازیابی">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </button>
                        <button class="deleted-action-btn deleted-action-delete"
                                @onclick="() => DeletePermanently(task.TaskId)"
                                title="حذف کامل">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<GetDeletedTasksQueryResultTasks>? _tasks;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDeletedTasks();
    }

    private async Task LoadDeletedTasks()
    {
        try
        {
            _isLoading = true;
            var result = await ApiService.SendAsync(
                () => ApiClient.GetDeletedTasksAsync(),
                showErrorToast: false);

            if (result != null && result.IsSuccess)
            {
                _tasks = result.Response?.Tasks?.ToList() ?? new List<GetDeletedTasksQueryResultTasks>();
            }
            else
            {
                _tasks = new List<GetDeletedTasksQueryResultTasks>();
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowToastError($"خطا: {ex.Message}");
            _tasks = new List<GetDeletedTasksQueryResultTasks>();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task RestoreTask(Guid taskId)
    {
        var result = await ApiService.SendAsync(
            () => ApiClient.RestoreTaskAsync(taskId),
            successMessage: "تسک با موفقیت بازیابی شد!",
            showErrorToast: false);

        if (result?.IsSuccess == true)
            await LoadDeletedTasks();
    }

    private async Task DeletePermanently(Guid taskId)
    {
        var confirmed = await JS.InvokeAsync<bool>(
            "confirm", "آیا از حذف کامل این تسک مطمئن هستید؟ این عمل قابل بازگشت نیست.");
        if (!confirmed) return;

        var result = await ApiService.SendAsync(
            () => ApiClient.DeleteTaskAsync(taskId),
            successMessage: "تسک با موفقیت حذف شد!",
            showErrorToast: false);

        if (result?.IsSuccess == true)
            await LoadDeletedTasks();
    }
}