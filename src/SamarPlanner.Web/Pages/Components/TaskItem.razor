@namespace SamarPlanner.Web.Pages.Components
@inject IApiClient ApiClient
@inject IToastService ToastService
@inject IApiService ApiService

<div class="task-item @(Occurrence.IsSkipped ? "skipped" : "") @GetPriorityClass() @(_showMenu ? "menu-open" : "")">
    <div class="task-left">
        <div class="task-status-icon">
            @switch (Occurrence.Status)
            {
                case GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.Pending:
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ffc107" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" />
                        <polyline points="12 6 12 12 16 14" />
                    </svg>
                    break;
                case GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.Done:
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#28a745" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                        <polyline points="22 4 12 14.01 9 11.01" />
                    </svg>
                    break;
                case GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.NotDone:
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#dc3545" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="15" y1="9" x2="9" y2="15" />
                        <line x1="9" y1="9" x2="15" y2="15" />
                    </svg>
                    break;
                case GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.AlmostDone:
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#6f42c1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                        <polyline points="12 8 12 12 14 14" />
                    </svg>
                    break;
                default:
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ffc107" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" />
                        <polyline points="12 6 12 12 16 14" />
                    </svg>
                    break;
            }
        </div>
        <div class="task-priority">
            <span class="priority-badge @GetPriorityColor()">
                @switch (Task.Priority)
                {
                    case GetTasksWithOccurrencesQueryResultTasksPriority.High:
                        <i class="bi bi-flag-fill"></i>
                        break;
                    case GetTasksWithOccurrencesQueryResultTasksPriority.Medium:
                        <i class="bi bi-flag"></i>
                        break;
                    case GetTasksWithOccurrencesQueryResultTasksPriority.Low:
                        <i class="bi bi-flag"></i>
                        break;
                    default:
                        <i class="bi bi-dash"></i>
                        break;
                }
            </span>
        </div>
    </div>

    <div class="task-info">
        <div class="task-title-wrapper">
            <div class="task-title @(Occurrence.IsSkipped ? "skipped-title" : "")">
                @Task.Title
            </div>
            @if (Occurrence.IsSkipped)
            {
                <span class="skipped-badge">نادیده گرفته شده</span>
            }
        </div>
        <div class="task-meta">
            @if (Occurrence.Time != null)
            {
                <span class="meta-item">
                    <i class="bi bi-clock"></i>
                    @Occurrence.Time.Value.ToString(@"hh\:mm")
                </span>
            }
            @if (Occurrence.Score.HasValue)
            {
                <span class="meta-item score">
                    <i class="bi bi-star-fill text-warning"></i>
                    @Occurrence.Score
                </span>
            }
        </div>
    </div>

    <div class="task-actions">
        <button class="btn-action btn-action-primary" @onclick="OpenChangeStatusModal" title="تغییر وضعیت">
            <i class="bi bi-arrow-repeat"></i>
        </button>
        <button class="btn-action btn-action-info" @onclick="OpenEditModal" title="ویرایش">
            <i class="bi bi-pencil"></i>
        </button>

        <div class="dropdown" @onclick:stopPropagation>
            <button class="btn-action btn-action-more" @onclick="ToggleMenu" title="بیشتر">
                <i class="bi bi-three-dots-vertical"></i>
            </button>
            @if (_showMenu)
            {
                <div class="dropdown-menu show" @onclick:stopPropagation>
                    @if (!Occurrence.IsSkipped)
                    {
                        <button class="dropdown-item" @onclick="OnSkip">
                            <i class="bi bi-eye-slash"></i> نادیده گرفتن
                        </button>
                    }
                    else
                    {
                        <button class="dropdown-item" @onclick="OnUnskip">
                            <i class="bi bi-eye"></i> لغو نادیده‌گیری
                        </button>
                    }
                    <button class="dropdown-item" @onclick="OpenChangeDateTimeModal">
                        <i class="bi bi-calendar-event"></i> تغییر تاریخ/زمان
                    </button>
                    <button class="dropdown-item text-danger" @onclick="OnDelete">
                        <i class="bi bi-trash3"></i> حذف
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@if (_showChangeStatusModal)
{
    <ChangeStatusModal TaskId="@Task.TaskId"
                       Date="@Occurrence.Date"
                       CurrentStatus="@Occurrence.Status"
                       CurrentScore="@Occurrence.Score"
                       OnStatusChanged="OnStatusChanged"
                       OnCloseRequested="CloseChangeStatusModal" />
}

@if (_showEditModal)
{
    <EditTaskModal TaskId="@Task.TaskId"
                   OnTaskUpdated="OnTaskUpdated"
                   OnCloseRequested="CloseEditModal" />
}

@if (_showChangeDateTimeModal)
{
    <ChangeDateAndTimeModal TaskId="@Task.TaskId"
                         CurrentDate="@Occurrence.Date"
                         CurrentTime="@Occurrence.Time"
                         OnDateTimeChanged="OnDateTimeChanged"
                         OnCloseRequested="CloseChangeDateTimeModal" />
}

@code {
    [Parameter] public GetTasksWithOccurrencesQueryResultTasks Task { get; set; } = null!;
    [Parameter] public GetTasksWithOccurrencesQueryResultTaskOccurrences Occurrence { get; set; } = null!;
    [Parameter] public EventCallback OnTaskUpdatedEvent { get; set; }

    private bool _showEditModal = false;
    private bool _showChangeStatusModal = false;
    private bool _showMenu = false;

    private void OpenEditModal() => _showEditModal = true;
    private void CloseEditModal() => _showEditModal = false;

    private void OpenChangeStatusModal() => _showChangeStatusModal = true;
    private void CloseChangeStatusModal() => _showChangeStatusModal = false;

    private void ToggleMenu() => _showMenu = !_showMenu;

    private bool _showChangeDateTimeModal = false;

    private void OpenChangeDateTimeModal()
    {
        _showChangeDateTimeModal = true;
        _showMenu = false;
    }

    private void CloseChangeDateTimeModal()
    {
        _showChangeDateTimeModal = false;
    }

    private async Task OnDateTimeChanged()
    {
        CloseChangeDateTimeModal();
        await OnTaskUpdatedEvent.InvokeAsync();
    }
    
    private async Task OnStatusChanged()
    {
        CloseChangeStatusModal();
        await OnTaskUpdatedEvent.InvokeAsync();
    }

    private async Task OnTaskUpdated()
    {
        CloseEditModal();
        CloseChangeStatusModal();
        await OnTaskUpdatedEvent.InvokeAsync();
    }

    private string GetPriorityClass()
    {
        if (Task.Priority == GetTasksWithOccurrencesQueryResultTasksPriority.High) return "priority-high";
        if (Task.Priority == GetTasksWithOccurrencesQueryResultTasksPriority.Medium) return "priority-medium";
        if (Task.Priority == GetTasksWithOccurrencesQueryResultTasksPriority.Low) return "priority-low";
        return "priority-none";
    }

    private string GetPriorityColor()
    {
        if (Task.Priority == GetTasksWithOccurrencesQueryResultTasksPriority.High) return "priority-high-color";
        if (Task.Priority == GetTasksWithOccurrencesQueryResultTasksPriority.Medium) return "priority-medium-color";
        if (Task.Priority == GetTasksWithOccurrencesQueryResultTasksPriority.Low) return "priority-low-color";
        return "priority-none-color";
    }

    private async Task OnSkip()
    {
        _showMenu = false;
        var request = new SkipOccurrenceRequest(Occurrence.Date, true);
        var result = await ApiService.SendAsync(
            apiCall: () => ApiClient.SkipOccurrenceAsync(Task.TaskId, request),
            successMessage: "عملیات با موفقیت انجام شد");
        if (result?.IsSuccess == true)
            await OnTaskUpdatedEvent.InvokeAsync();
    }

    private async Task OnUnskip()
    {
        _showMenu = false;
        var request = new SkipOccurrenceRequest(Occurrence.Date, false);
        var result = await ApiService.SendAsync(
            apiCall: () => ApiClient.SkipOccurrenceAsync(Task.TaskId, request),
            successMessage: "عملیات با موفقیت انجام شد");
        if (result?.IsSuccess == true)
            await OnTaskUpdatedEvent.InvokeAsync();
    }

    private async Task OnDelete()
    {
        _showMenu = false;
        var result = await ApiService.SendAsync(
            apiCall: () => ApiClient.SoftDeleteTaskAsync(Task.TaskId),
            successMessage: "عملیات با موفقیت انجام شد");
        if (result?.IsSuccess == true)
            await OnTaskUpdatedEvent.InvokeAsync();
    }
}