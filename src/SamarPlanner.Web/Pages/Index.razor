@page "/"
@inject  IToastService ToastService
@inject Blazored.Toast.Services.IToastService t

<div class="index-page">
    <div class="hero-icon">
        <i class="bi bi-calendar2-week"></i>
    </div>
    <h1>به SamarPlanner خوش آمدید</h1>
    <p class="subtitle">برنامه‌ریزی روزانه‌تان را آسان کنید</p>
    <a href="/login" class="btn btn-login">
        <i class="bi bi-box-arrow-in-right"></i>
        شروع کنید
    </a>
</div>

@code
{
    protected override void OnInitialized()
    {
        base.OnInitialized();
        
        ToastService.ShowToastInfo("kazem");
        t.ShowWarning("k");
    }
}
