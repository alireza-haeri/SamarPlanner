@inherits LayoutComponentBase
@using Blazored.Toast
@using Blazored.Toast.Configuration
@using SamarPlanner.Web.Components
@using SamarPlanner.Web.Services
@inject NavigationManager NavigationManager
@inject ModalService ModalService

<div class="sub-layout">
    @* ── Topbar ── *@
    <SubTopbar />

    @* ── Section Tabs ── *@
    <header class="sub-header">
        <nav class="task-nav">
            <NavLink href="/tasks/daily" class="task-nav-link" ActiveClass="is-active">
                <i class="bi bi-calendar-day"></i>
                <span>روزانه</span>
            </NavLink>
            <NavLink href="/tasks/weekly" class="task-nav-link" ActiveClass="is-active">
                <i class="bi bi-calendar-week"></i>
                <span>هفتگی</span>
            </NavLink>

            <div class="task-nav-divider"></div>

            <div class="task-nav-more">
                <button class="task-nav-link task-nav-more-btn" @onclick="ToggleDropdown">
                    <i class="bi bi-three-dots"></i>
                </button>
                @if (_showDropdown)
                {
                    <div class="task-nav-more-backdrop" @onclick="CloseDropdown"></div>
                    <div class="task-nav-more-menu" @onclick:stopPropagation>
                        <button class="task-nav-more-item" @onclick="@(() => { CloseDropdown(); NavigationManager.NavigateTo("/tasks/deleted"); })">
                            <span class="task-nav-more-icon"><i class="bi bi-trash3"></i></span>
                            <span>حذف شده‌ها</span>
                        </button>
                    </div>
                }
            </div>
        </nav>
    </header>

    @* ── Content ── *@
    <main class="sub-content">
        @Body
    </main>

    @* ── FAB ── *@
    <div class="sub-fab">
        <button class="fab-button" @onclick="OpenAddTaskModal" title="تسک جدید">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
        </button>
    </div>
</div>

<BottomNav ActiveSection="tasks" />
<ModalPortal />
<BlazoredToasts Position="ToastPosition.TopRight" />
<script src="js/task-dropdown.js"></script>

@code {
    private bool _showDropdown;

    protected override void OnInitialized()
    {
        ModalService.OnChanged += HandleModalChanged;
    }

    private void HandleModalChanged() => InvokeAsync(StateHasChanged);

    private void OpenAddTaskModal()
    {
        ModalService.Show(builder =>
        {
            builder.OpenComponent<AddTaskFormModal>(0);
            builder.AddAttribute(1, nameof(AddTaskFormModal.OnTaskAdded),
                EventCallback.Factory.Create(this, () =>
                {
                    ModalService.Close();
                    NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
                }));
            builder.AddAttribute(2, nameof(AddTaskFormModal.OnCloseRequested),
                EventCallback.Factory.Create(this, () => ModalService.Close()));
            builder.CloseComponent();
        });
    }

    private void ToggleDropdown() => _showDropdown = !_showDropdown;
    private void CloseDropdown() => _showDropdown = false;

    public void Dispose()
    {
        ModalService.OnChanged -= HandleModalChanged;
    }
}