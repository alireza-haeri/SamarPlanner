@inherits LayoutComponentBase
@using Blazored.Toast
@using Blazored.Toast.Configuration
@using SamarPlanner.Web.Services
@inject NavigationManager NavigationManager

<div class="task-layout">
    <div class="task-header">
        <div class="task-nav">
            <NavLink href="/tasks/daily" class="nav-link" ActiveClass="active">
                <i class="bi bi-calendar-day"></i> روزانه
            </NavLink>
            <NavLink href="/tasks/weekly" class="nav-link" ActiveClass="active">
                <i class="bi bi-calendar-week"></i> هفتگی
            </NavLink>
            <NavLink href="/tasks/month" class="nav-link" ActiveClass="active">
                <i class="bi bi-calendar-month"></i> ماهانه
            </NavLink>

            
            <div class="nav-dropdown">
                <button class="nav-link nav-dropdown-toggle" @onclick="ToggleDropdown">
                    <i class="bi bi-three-dots-vertical"></i>
                </button>
                @if (_showDropdown)
                {
                    <div class="nav-dropdown-menu" @onclick:stopPropagation>
                        <button class="dropdown-item" @onclick="@(() =>
                                                                {
                                                                    CloseDropdown();
                                                                    NavigationManager.NavigateTo("/tasks/deleted");
                                                                })">
                            <i class="bi bi-trash3"></i> حذف شده‌ها
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <main class="task-content">
        @Body
    </main>

    <div class="fab-container">
        <button class="btn-fab" @onclick="OpenAddTaskModal">
            <i class="bi bi-plus-lg"></i>
        </button>
    </div>
</div>

@if (_showAddTaskModal)
{
    <div class="modal-overlay">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h5>تسک جدید</h5>
                <button class="btn-close" @onclick="CloseModal"></button>
            </div>
            <div class="modal-body">
                <AddTaskForm OnTaskAdded="OnTaskAdded"/>
            </div>
        </div>
    </div>
}

<BlazoredToasts Position="ToastPosition.TopRight"/>

@code {
    private bool _showAddTaskModal = false;
    private bool _showDropdown = false;

    private void OpenAddTaskModal()
    {
        _showAddTaskModal = true;
    }

    private void CloseModal()
    {
        _showAddTaskModal = false;
    }

    private Task OnTaskAdded()
    {
        CloseModal();
        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
        return Task.CompletedTask;
    }

    private void ToggleDropdown()
    {
        _showDropdown = !_showDropdown;
    }

    private void CloseDropdown()
    {
        _showDropdown = false;
    }

}