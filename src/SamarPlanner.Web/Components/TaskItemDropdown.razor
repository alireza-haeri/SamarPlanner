@namespace SamarPlanner.Web.Components
@using Microsoft.JSInterop
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="ti-dropdown-wrapper @(IsOpen ? "is-open" : "")" @ref="_wrapperRef">
    <button class="btn-action btn-action-more" @onclick="Toggle" @onclick:stopPropagation title="@Title">
        @ButtonContent
    </button>

    @if (IsOpen)
    {
        <div class="ti-dropdown-backdrop" @onclick="Close" @onclick:stopPropagation></div>
        <div class="ti-dropdown-menu" @ref="_menuRef" @onclick:stopPropagation>
            @ChildContent
            @* دکمه لغو فقط روی موبایل *@
            <button class="ti-dropdown-cancel ti-dropdown-cancel-mobile" @onclick="Close" @onclick:stopPropagation>
                بستن
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public RenderFragment? ButtonContent { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string Title { get; set; } = "بیشتر";
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public bool IsOpen { get; set; }

    private ElementReference _wrapperRef;
    private ElementReference _menuRef;
    private DotNetObjectReference<TaskItemDropdown>? _dotNetRef;
    private bool _jsInitialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsOpen && !_jsInitialized)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            try
            {
                await JS.InvokeVoidAsync("taskDropdown.init", _dotNetRef, _menuRef);
                _jsInitialized = true;
            }
            catch { }
        }
    }

    public void Toggle()
    {
        IsOpen = !IsOpen;
        if (!IsOpen) _jsInitialized = false;
        IsOpenChanged.InvokeAsync(IsOpen);
    }

    public void Close()
    {
        IsOpen = false;
        _jsInitialized = false;
        IsOpenChanged.InvokeAsync(IsOpen);
    }

    [JSInvokable]
    public void CloseFromJS()
    {
        IsOpen = false;
        _jsInitialized = false;
        InvokeAsync(() =>
        {
            IsOpenChanged.InvokeAsync(IsOpen);
            StateHasChanged();
        });
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_dotNetRef is not null)
            {
                await JS.InvokeVoidAsync("taskDropdown.dispose", _dotNetRef);
                _dotNetRef.Dispose();
            }
        }
        catch { }
    }
}