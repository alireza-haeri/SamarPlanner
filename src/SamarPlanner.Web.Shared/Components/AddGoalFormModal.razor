@using SamarPlanner.Web.Shared.Pages.Components
@namespace SamarPlanner.Web.Shared.Components

<div class="modal-overlay" @onclick="OnClose">
    <div class="modal-content modal-content--lg" @onclick:stopPropagation>
        <div class="modal-header">
            <h5>هدف جدید</h5>
            <button class="btn-close" @onclick="OnClose"></button>
        </div>
        <div class="modal-body">
            <AddGoalForm OnGoalAdded="OnGoalAdded" />
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnGoalAdded { get; set; }
    [Parameter] public EventCallback OnCloseRequested { get; set; }

    private async Task OnClose() => await OnCloseRequested.InvokeAsync();
}