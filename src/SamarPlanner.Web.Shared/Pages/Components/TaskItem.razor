@using SamarPlanner.Web.Services
@using SamarPlanner.Web.Shared.Components
@using SamarPlanner.Web.Shared.Services
@namespace SamarPlanner.Web.Shared.Pages.Components
@inject IApiClient ApiClient
@inject IToastService ToastService
@inject IApiService ApiService
@inject ModalService ModalService

<div class="task-item @(Occurrence.IsSkipped ? "skipped" : "") @GetPriorityClass() @(_showMenu ? "is-menu-open" : "")">

    @* ── Status Button ── *@
    <button class="task-status-btn @GetStatusBgClass()" @onclick="OpenChangeStatusModal" @onclick:stopPropagation
            title="تغییر وضعیت">
        @switch (Occurrence.Status)
        {
            case GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.Pending:
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                     stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                </svg>
                break;
            case GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.Done:
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                break;
            case GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.NotDone:
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                     stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="15" y1="9" x2="9" y2="15"/>
                    <line x1="9" y1="9" x2="15" y2="15"/>
                </svg>
                break;
            case GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.AlmostDone:
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    <polyline points="12 8 12 12 14 14"/>
                </svg>
                break;
        }
    </button>

    @* ── Content ── *@
    <div class="task-content">
        <div class="task-title-row">
            <span class="task-title @(Occurrence.IsSkipped ? "skipped-title" : "")">
                @Task.Title
            </span>
            @if (Occurrence.IsSkipped)
            {
                <span class="skipped-badge">نادیده گرفته شده</span>
            }
        </div>
        <div class="task-meta-row">

            @if (Task.Priority.HasValue)
            {
                <span class="task-chip task-chip-@GetPriorityName()">
                    <i class="bi bi-flag-fill"></i>
                    @GetPriorityLabel()
                </span>
            }
            @if (Occurrence.Time != null)
            {
                <span class="task-chip">
                    <i class="bi bi-clock"></i>
                    @Occurrence.Time.Value.ToString(@"hh\:mm")
                </span>
            }
            @if (Occurrence.Score.HasValue)
            {
                <span class="task-chip task-chip-score">
                    <i class="bi bi-star-fill"></i>
                    @Occurrence.Score
                </span>
            }
        </div>
    </div>

    @if (ShowTaskActions)
    {
        @* ── Actions ── *@
        <div class="task-actions">
            <button class="btn-action btn-action-edit" @onclick="OpenEditModal" @onclick:stopPropagation title="ویرایش">
                <i class="bi bi-pencil"></i>
            </button>

            <TaskItemDropdown @bind-IsOpen="_showMenu" Title="بیشتر">
                <ButtonContent>
                    <i class="bi bi-three-dots"></i>
                </ButtonContent>
                <ChildContent>
                    @if (!Occurrence.IsSkipped)
                    {
                        <button class="ti-dropdown-item" @onclick="OnSkip">
                            <span class="ti-dropdown-icon"><i class="bi bi-eye-slash"></i></span>
                            <span>نادیده گرفتن</span>
                        </button>
                    }
                    else
                    {
                        <button class="ti-dropdown-item" @onclick="OnUnskip">
                            <span class="ti-dropdown-icon"><i class="bi bi-eye"></i></span>
                            <span>لغو نادیده‌گیری</span>
                        </button>
                    }
                    <button class="ti-dropdown-item" @onclick="OpenChangeDateTimeModal">
                        <span class="ti-dropdown-icon"><i class="bi bi-calendar-event"></i></span>
                        <span>تغییر تاریخ/زمان</span>
                    </button>
                    <div class="ti-dropdown-divider"></div>
                    <button class="ti-dropdown-item ti-dropdown-item--danger" @onclick="OnDelete">
                        <span class="ti-dropdown-icon"><i class="bi bi-trash3"></i></span>
                        <span>حذف تسک</span>
                    </button>
                </ChildContent>
            </TaskItemDropdown>
        </div>
    }
</div>

@code {
    [Parameter] public GetTasksWithOccurrencesQueryResultTasks Task { get; set; } = null!;
    [Parameter] public GetTasksWithOccurrencesQueryResultTaskOccurrences Occurrence { get; set; } = null!;
    [Parameter] public EventCallback OnTaskUpdatedEvent { get; set; }
    [Parameter] public bool ShowTaskActions { get; set; } = true;

    private bool _showMenu;

    private void OpenChangeStatusModal()
    {
        var taskId = Task.TaskId;
        var date = Occurrence.Date;
        var status = Occurrence.Status;
        var score = Occurrence.Score;

        ModalService.Show(builder =>
        {
            builder.OpenComponent<ChangeStatusModal>(0);
            builder.AddAttribute(1, nameof(ChangeStatusModal.TaskId), taskId);
            builder.AddAttribute(2, nameof(ChangeStatusModal.Date), date);
            builder.AddAttribute(3, nameof(ChangeStatusModal.CurrentStatus), status);
            builder.AddAttribute(4, nameof(ChangeStatusModal.CurrentScore), score);
            builder.AddAttribute(5, nameof(ChangeStatusModal.OnStatusChanged),
                EventCallback.Factory.Create(this, async () =>
                {
                    ModalService.Close();
                    await OnTaskUpdatedEvent.InvokeAsync();
                }));
            builder.AddAttribute(6, nameof(ChangeStatusModal.OnCloseRequested),
                EventCallback.Factory.Create(this, () => ModalService.Close()));
            builder.CloseComponent();
        });
    }

    private void OpenEditModal()
    {
        var taskId = Task.TaskId;
        ModalService.Show(builder =>
        {
            builder.OpenComponent<EditTaskModal>(0);
            builder.AddAttribute(1, nameof(EditTaskModal.TaskId), taskId);
            builder.AddAttribute(2, nameof(EditTaskModal.OnTaskUpdated),
                EventCallback.Factory.Create(this, async () =>
                {
                    ModalService.Close();
                    await OnTaskUpdatedEvent.InvokeAsync();
                }));
            builder.AddAttribute(3, nameof(EditTaskModal.OnCloseRequested),
                EventCallback.Factory.Create(this, () => ModalService.Close()));
            builder.CloseComponent();
        });
    }

    private void OpenChangeDateTimeModal()
    {
        _showMenu = false;
        var taskId = Task.TaskId;
        var currentDate = Occurrence.Date;
        var currentTime = Occurrence.Time;

        ModalService.Show(builder =>
        {
            builder.OpenComponent<ChangeDateAndTimeModal>(0);
            builder.AddAttribute(1, nameof(ChangeDateAndTimeModal.TaskId), taskId);
            builder.AddAttribute(2, nameof(ChangeDateAndTimeModal.CurrentDate), currentDate);
            builder.AddAttribute(3, nameof(ChangeDateAndTimeModal.CurrentTime), currentTime);
            builder.AddAttribute(4, nameof(ChangeDateAndTimeModal.OnDateTimeChanged),
                EventCallback.Factory.Create(this, async () =>
                {
                    ModalService.Close();
                    await OnTaskUpdatedEvent.InvokeAsync();
                }));
            builder.AddAttribute(5, nameof(ChangeDateAndTimeModal.OnCloseRequested),
                EventCallback.Factory.Create(this, () => ModalService.Close()));
            builder.CloseComponent();
        });
    }

    private async Task OnSkip()
    {
        _showMenu = false;
        var request = new SkipOccurrenceRequest(Occurrence.Date, true);
        var result = await ApiService.SendAsync(
            apiCall: () => ApiClient.SkipOccurrenceAsync(Task.TaskId, request),
            successMessage: "عملیات با موفقیت انجام شد");
        if (result?.IsSuccess == true) await OnTaskUpdatedEvent.InvokeAsync();
    }

    private async Task OnUnskip()
    {
        _showMenu = false;
        var request = new SkipOccurrenceRequest(Occurrence.Date, false);
        var result = await ApiService.SendAsync(
            apiCall: () => ApiClient.SkipOccurrenceAsync(Task.TaskId, request),
            successMessage: "عملیات با موفقیت انجام شد");
        if (result?.IsSuccess == true) await OnTaskUpdatedEvent.InvokeAsync();
    }

    private async Task OnDelete()
    {
        _showMenu = false;
        var result = await ApiService.SendAsync(
            apiCall: () => ApiClient.SoftDeleteTaskAsync(Task.TaskId),
            successMessage: "عملیات با موفقیت انجام شد");
        if (result?.IsSuccess == true) await OnTaskUpdatedEvent.InvokeAsync();
    }

    private string GetPriorityClass()
    {
        return Task.Priority switch
        {
            GetTasksWithOccurrencesQueryResultTasksPriority.High => "priority-high",
            GetTasksWithOccurrencesQueryResultTasksPriority.Medium => "priority-medium",
            GetTasksWithOccurrencesQueryResultTasksPriority.Low => "priority-low",
            _ => "priority-none"
        };
    }

    private string GetStatusBgClass()
    {
        return Occurrence.Status switch
        {
            GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.Pending => "status-pending",
            GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.Done => "status-done",
            GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.NotDone => "status-not-done",
            GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.AlmostDone => "status-almost",
            _ => "status-pending"
        };
    }

    private string GetPriorityName()
    {
        return Task.Priority switch
        {
            GetTasksWithOccurrencesQueryResultTasksPriority.High => "high",
            GetTasksWithOccurrencesQueryResultTasksPriority.Medium => "medium",
            GetTasksWithOccurrencesQueryResultTasksPriority.Low => "low",
            _ => ""
        };
    }

    private string GetPriorityLabel()
    {
        return Task.Priority switch
        {
            GetTasksWithOccurrencesQueryResultTasksPriority.High => "بالا",
            GetTasksWithOccurrencesQueryResultTasksPriority.Medium => "متوسط",
            GetTasksWithOccurrencesQueryResultTasksPriority.Low => "پایین",
            _ => ""
        };
    }

}