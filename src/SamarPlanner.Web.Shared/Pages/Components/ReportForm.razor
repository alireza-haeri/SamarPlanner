@namespace SamarPlanner.Web.Shared.Pages.Components
@using SamarPlanner.Web.Services
@using SamarPlanner.Web.Shared.Helpers
@using SamarPlanner.Web.Shared.Models
@using SamarPlanner.Web.Shared.Services
@inject IApiClient ApiClient
@inject IApiService ApiService
@inject IToastService ToastService
@implements IDisposable

<EditForm EditContext="@_editContext" OnSubmit="@HandleSubmit">
    <DataAnnotationsValidator/>
    <ValidationSummary class="rf-validation"/>

    @* ── Title ── *@
    <div class="rf-field">
        <label class="rf-label">عنوان گزارش</label>
        <InputText class="rf-input" @bind-Value="_model.Title" placeholder="اختیاری"/>
    </div>

    @* ── Note ── *@
    <div class="rf-field">
        <label class="rf-label">متن گزارش</label>
        <InputTextArea class="rf-input" @bind-Value="_model.Note" rows="4" placeholder="شرح گزارش را وارد کنید"/>
    </div>

    @* ── Score + Dates ── *@
    <div class="rf-row-3">
        <div class="rf-field">
            <label class="rf-label">امتیاز</label>
            <InputNumber TValue="int?" class="rf-input" @bind-Value="_model.Score" placeholder="—"/>
        </div>
        <div class="rf-field">
            <label class="rf-label">شروع دوره (شمسی)</label>
            <InputText class="rf-input" @bind-Value="_model.PeriodStart" placeholder="1404/01/01"/>
        </div>
        <div class="rf-field">
            <label class="rf-label">پایان دوره (شمسی)</label>
            <InputText class="rf-input" @bind-Value="_model.PeriodEnd" placeholder="1404/01/01"/>
        </div>
    </div>

    @* ── Highlights ── *@
    <div class="rf-field">
        <div class="hl-section-header">
            <label class="rf-label rf-label-with-icon">
                <i class="bi bi-lightbulb"></i>
                نکات برجسته
            </label>
            <span class="hl-count">@_model.Highlights.Count مورد</span>
        </div>

        <div class="hl-list">
            @for (var i = 0; i < _model.Highlights.Count; i++)
            {
                var index = i;
                var hl = _model.Highlights[index];
                <div class="hl-card hl-@hl.Type.ToString().ToLowerInvariant()" @key="index">
                    @* Header: Type Toggle + Delete *@
                    <div class="hl-header">
                        <div class="hl-type-group">
                            <button type="button"
                                    class="hl-type-btn hl-type-positive @(hl.Type == ReportHighlightDtoType.Positive ? "active" : "")"
                                    @onclick="() => SetHighlightType(index, ReportHighlightDtoType.Positive)">
                                <i class="bi bi-check-circle-fill"></i>
                                <span>مثبت</span>
                            </button>
                            <button type="button"
                                    class="hl-type-btn hl-type-negative @(hl.Type == ReportHighlightDtoType.Negative ? "active" : "")"
                                    @onclick="() => SetHighlightType(index, ReportHighlightDtoType.Negative)">
                                <i class="bi bi-x-circle-fill"></i>
                                <span>منفی</span>
                            </button>
                            <button type="button"
                                    class="hl-type-btn hl-type-lesson @(hl.Type == ReportHighlightDtoType.Lesson ? "active" : "")"
                                    @onclick="() => SetHighlightType(index, ReportHighlightDtoType.Lesson)">
                                <i class="bi bi-lightbulb-fill"></i>
                                <span>درس</span>
                            </button>
                        </div>
                        <button type="button" class="hl-remove-btn"
                                @onclick="() => RemoveHighlight(index)"
                                disabled="@(_model.Highlights.Count <= 1)"
                                title="حذف نکته">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </div>

                    @* Input + Suggestions *@
                    <div class="hl-input-wrap">
                        <i class="hl-input-icon bi bi-pencil"></i>
                        <input type="text" class="hl-input"
                               value="@hl.Text"
                               @oninput="e => OnHighlightInput(e, index)"
                               @onfocus="() => OnHighlightFocus(index)"
                               @onblur="OnHighlightBlur"
                               placeholder="متن نکته را بنویسید..."/>

                        @if (_isLoadingSuggestion && _activeSuggestionIndex == index)
                        {
                            <div class="hl-suggestions-loading">
                                <span class="spinner-border spinner-border-sm"></span>
                            </div>
                        }

                        @if (_activeSuggestionIndex == index && _suggestions.Any())
                        {
                            <div class="hl-suggestions">
                                @foreach (var sug in _suggestions)
                                {
                                    <button type="button"
                                            class="hl-sug-item"
                                            @onmousedown:preventDefault
                                            @onmousedown="@(() => ApplySuggestion(index, sug))"
                                    >
                                        <span class="hl-sug-badge hl-sug-@sug.Type.ToString().ToLowerInvariant()">
                                            @GetSuggestionTypeLabel((ReportHighlightDtoType)sug.Type)
                                        </span>
                                        <span class="hl-sug-text">@sug.Text</span>
                                        <i class="hl-sug-arrow bi bi-chevron-left"></i>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <button type="button" class="hl-add-btn" @onclick="AddHighlight">
            <i class="bi bi-plus-circle-dotted"></i>
            <span>افزودن نکته جدید</span>
        </button>
    </div>

    @* ── Submit ── *@
    <button type="submit" class="rf-submit" disabled="@_isLoading">
        @if (_isLoading)
        {
            <span class="spinner-border spinner-border-sm"></span>
            <span>در حال ذخیره...</span>
        }
        else
        {
            <span>@(ReportId.HasValue ? "به‌روزرسانی گزارش" : "ثبت گزارش")</span>
        }
    </button>
</EditForm>

@code {
    [Parameter] public Guid? ReportId { get; set; }
    [Parameter] public DateTimeOffset DefaultPeriodStart { get; set; } = DateTimeOffset.Now.Date;
    [Parameter] public DateTimeOffset DefaultPeriodEnd { get; set; } = DateTimeOffset.Now.Date;
    [Parameter] public ReportEditorModel? InitialModel { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private ReportEditorModel _model = new();
    private EditContext? _editContext;
    private bool _isLoading;

    // ── Autocomplete State ──
    private int? _activeSuggestionIndex;
    private List<GetHighlightSuggestionsQueryResponseSuggestion> _suggestions = new();
    private bool _isLoadingSuggestion;
    private CancellationTokenSource? _suggestionCts;

    protected override void OnParametersSet()
    {
        if (_editContext is not null)
            return;

        _model = InitialModel?.Clone() ?? new ReportEditorModel
        {
            PeriodStart = DefaultPeriodStart.ToPersianDate(),
            PeriodEnd = DefaultPeriodEnd.ToPersianDate(),
            Highlights = [new ReportHighlightModel()]
        };

        if (!_model.Highlights.Any())
            _model.Highlights.Add(new ReportHighlightModel());

        _editContext = new EditContext(_model);
    }

    // ──────────────────────────────────
    //  Highlight Type
    // ──────────────────────────────────

    private void SetHighlightType(int index, ReportHighlightDtoType type)
    {
        _model.Highlights[index].Type = type;
    }

    // ──────────────────────────────────
    //  Highlight CRUD
    // ──────────────────────────────────

    private void AddHighlight()
    {
        _model.Highlights.Add(new ReportHighlightModel());
        _editContext?.NotifyFieldChanged(new FieldIdentifier(_model, nameof(ReportEditorModel.Highlights)));
    }

    private void RemoveHighlight(int index)
    {
        if (_model.Highlights.Count <= 1)
            return;

        _model.Highlights.RemoveAt(index);
        ClearSuggestions();
        _editContext?.NotifyFieldChanged(new FieldIdentifier(_model, nameof(ReportEditorModel.Highlights)));
    }

    // ──────────────────────────────────
    //  Autocomplete
    // ──────────────────────────────────

    private async Task OnHighlightInput(ChangeEventArgs e, int index)
    {
        var text = e.Value?.ToString() ?? "";
        _model.Highlights[index].Text = text;

        // --- لغو کردن درخواست قبلی با امنیت کامل ---
        if (_suggestionCts != null)
        {
            try
            {
                _suggestionCts.Cancel(); // ممکن است CTS قبلاً Dispose شده باشد
            }
            catch (ObjectDisposedException)
            {
                // اگر قبلاً Dispose شده بود، نادیده بگیر
            }
            finally
            {
                _suggestionCts.Dispose();
                _suggestionCts = null;
            }
        }

        if (text.Trim().Length >= 3)
        {
            var cts = new CancellationTokenSource();
            _suggestionCts = cts;

            try
            {
                _isLoadingSuggestion = true;
                StateHasChanged();

                // تأخیر debounce
                try
                {
                    await Task.Delay(350, cts.Token);
                }
                catch (OperationCanceledException)
                {
                    // اگر در حین تأخیر لغو شد، خارج شو
                    return;
                }

                if (cts.IsCancellationRequested)
                    return;

                var result = await ApiService.SendAsync(
                    apiCall: () => ApiClient.GetHighlightsSuggestionsAsync(text.Trim(), cts.Token),
                    showErrorToast: false);

                if (!cts.IsCancellationRequested)
                {
                    if (result?.IsSuccess is true && result.Response?.Suggestions.Any() == true)
                    {
                        _suggestions = result.Response.Suggestions.ToList();
                        _activeSuggestionIndex = index;
                    }
                    else
                    {
                        _suggestions.Clear();
                    }

                    _isLoadingSuggestion = false;
                }
            }
            catch (OperationCanceledException)
            {
            }
            catch (ObjectDisposedException)
            {
                // اگر CTS در حین عملیات Dispose شد، فقط پاک کن
                _suggestions.Clear();
                _isLoadingSuggestion = false;
            }
            catch
            {
                _suggestions.Clear();
                _isLoadingSuggestion = false;
            }
        }
        else
        {
            ClearSuggestions();
        }

        await InvokeAsync(StateHasChanged);
    }

    private void OnHighlightFocus(int index)
    {
        // If text already has 3+ chars, re-show cached suggestions
        var text = _model.Highlights[index].Text;
        if (!string.IsNullOrWhiteSpace(text) && text.Trim().Length >= 3 && _suggestions.Any())
        {
            _activeSuggestionIndex = index;
        }
    }

    private async Task OnHighlightBlur()
    {
        // Delay so @onmousedown on suggestions can fire first
        await Task.Delay(250);
        ClearSuggestions();
        await InvokeAsync(StateHasChanged);
    }

    private void ApplySuggestion(int index, GetHighlightSuggestionsQueryResponseSuggestion suggestion)
    {
        _model.Highlights[index].Text = suggestion.Text;
        _model.Highlights[index].Type = MapHighlightType((ReportHighlightDtoType)suggestion.Type);
        ClearSuggestions();
    }

    private void ClearSuggestions()
    {
        _activeSuggestionIndex = null;
        _suggestions.Clear();
        _isLoadingSuggestion = false;
    }

    // ──────────────────────────────────
    //  Mapping Helpers
    // ──────────────────────────────────

    private static ReportHighlightDtoType MapHighlightType(ReportHighlightDtoType type)
    {
        return type switch
        {
            ReportHighlightDtoType.Positive => ReportHighlightDtoType.Positive,
            ReportHighlightDtoType.Negative => ReportHighlightDtoType.Negative,
            ReportHighlightDtoType.Lesson => ReportHighlightDtoType.Lesson,
            _ => ReportHighlightDtoType.Positive
        };
    }

    private static string GetSuggestionTypeLabel(ReportHighlightDtoType type)
    {
        return type switch
        {
            ReportHighlightDtoType.Positive => "مثبت",
            ReportHighlightDtoType.Negative => "منفی",
            ReportHighlightDtoType.Lesson => "درس‌آموخته",
            _ => ""
        };
    }

    // ──────────────────────────────────
    //  Submit
    // ──────────────────────────────────

    private async Task HandleSubmit()
    {
        if (_isLoading)
            return;

        _isLoading = true;

        if (_editContext is null || !_editContext.Validate())
        {
            _isLoading = false;
            return;
        }

        var periodStart = PersianDateHelper.ToGregorianDateTime(_model.PeriodStart);
        if (!periodStart.HasValue)
        {
            ToastService.ShowToastError("تاریخ شروع معتبر نیست!");
            _isLoading = false;
            return;
        }

        var periodEnd = PersianDateHelper.ToGregorianDateTime(_model.PeriodEnd);
        if (!periodEnd.HasValue)
        {
            ToastService.ShowToastError("تاریخ پایان معتبر نیست!");
            _isLoading = false;
            return;
        }

        if (periodEnd.Value.Date < periodStart.Value.Date)
        {
            ToastService.ShowToastError("تاریخ پایان نمی‌تواند قبل از تاریخ شروع باشد!");
            _isLoading = false;
            return;
        }

        var highlights = _model.Highlights
            .Where(x => !string.IsNullOrWhiteSpace(x.Text))
            .Select(x => new ReportHighlightDto(x.Text.Trim(), x.Type))
            .ToList();

        if (ReportId.HasValue)
        {
            var request = new UpdateReportRequest(
                title: string.IsNullOrWhiteSpace(_model.Title) ? null : _model.Title.Trim(),
                note: _model.Note.Trim(),
                score: _model.Score,
                periodStart: periodStart.Value.DateTime,
                periodEnd: periodEnd.Value.DateTime,
                highlights: highlights);

            var result = await ApiService.SendAsync(
                apiCall: () => ApiClient.UpdateReportAsync(ReportId.Value, request),
                successMessage: "گزارش با موفقیت به‌روزرسانی شد!",
                showErrorToast: true);

            if (result?.IsSuccess is true)
                await OnSaved.InvokeAsync();
        }
        else
        {
            var request = new CreateReportRequest(
                title: string.IsNullOrWhiteSpace(_model.Title) ? null : _model.Title.Trim(),
                note: _model.Note.Trim(),
                score: _model.Score,
                periodStart: periodStart.Value.DateTime,
                periodEnd: periodEnd.Value.DateTime,
                highlights: highlights);

            var result = await ApiService.SendAsync(
                apiCall: () => ApiClient.CreateReportAsync(request),
                successMessage: "گزارش با موفقیت ثبت شد!",
                showErrorToast: true);

            if (result?.IsSuccess is true)
                await OnSaved.InvokeAsync();
        }

        _isLoading = false;
    }

    // ──────────────────────────────────
    //  Disposal
    // ──────────────────────────────────

    public void Dispose()
    {
        if (_suggestionCts != null)
        {
            try
            {
                _suggestionCts.Cancel();
            }
            catch (ObjectDisposedException)
            {
                // اگر قبلاً Dispose شده، نادیده بگیر
            }
            finally
            {
                _suggestionCts.Dispose();
                _suggestionCts = null;
            }
        }
    }

}