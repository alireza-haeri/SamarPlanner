@namespace SamarPlanner.Web.Shared.Pages.Components

@using SamarPlanner.Web.Shared.Helpers
@using SamarPlanner.Web.Shared.Services
@inherits ComponentBase
@inject IApiClient ApiClient
@inject IToastService ToastService
@inject IApiService ApiService

<div class="modal-overlay" @onclick="OnClose">
    <div class="modal-content" @onclick:stopPropagation>
        <div class="modal-header">
            <h5>تغییر تاریخ / زمان</h5>
            <button class="btn-close" @onclick="OnClose"></button>
        </div>
        <div class="modal-body">
            <EditForm EditContext="@_formHelper.EditContext" OnSubmit="@Submit">
                <ValidationSummary class="text-danger mb-3"/>

                <div class="mb-3">
                    <label class="form-label">تاریخ (شمسی)</label>
                    <InputText class="form-control" @bind-Value="_formHelper.Model.NewPersianDate"
                               placeholder="مثلاً 1404/01/01"/>
                    <small class="text-muted">تاریخ فعلی: @_currentPersianDate</small>
                </div>

                <div class="mb-3">
                    <label class="form-label">زمان (ساعت:دقیقه)</label>
                    <InputText class="form-control" @bind-Value="_formHelper.Model.NewTime" placeholder="مثلاً 14:30"/>
                    <small class="text-muted">زمان فعلی: @_currentTime</small>
                </div>

                <button type="submit" class="btn btn-primary w-100" disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>در حال ذخیره...</span>
                    }
                    else
                    {
                        <span>اعمال تغییرات</span>
                    }
                </button>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid TaskId { get; set; }
    [Parameter] public DateTimeOffset CurrentDate { get; set; }
    [Parameter] public TimeSpan? CurrentTime { get; set; }
    [Parameter] public EventCallback OnDateTimeChanged { get; set; }
    [Parameter] public EventCallback OnCloseRequested { get; set; }

    private FormHelper<ChangeDateTimeModel> _formHelper = null!;
    private bool _isLoading = false;
    private string _currentPersianDate = "";
    private string _currentTime = "";

    protected override void OnInitialized()
    {
        _currentPersianDate = CurrentDate.ToPersianDate();
        _currentTime = CurrentTime?.ToString(@"hh\:mm") ?? "";

        _formHelper = new FormHelper<ChangeDateTimeModel>(new ChangeDateTimeModel
        {
            NewPersianDate = _currentPersianDate,
            NewTime = _currentTime
        });
    }

    private async Task Submit()
    {
        if (_isLoading) return;
        _isLoading = true;

        _formHelper.ClearErrors();

        if (!_formHelper.Validate())
        {
            _isLoading = false;
            return;
        }

        var hasChanges = false;
        var dateChanged = false;
        var timeChanged = false;

        // بررسی تغییر تاریخ
        if (!string.IsNullOrEmpty(_formHelper.Model.NewPersianDate) &&
            _formHelper.Model.NewPersianDate != _currentPersianDate)
        {
            var gregorian = PersianDateHelper.ToGregorianDateTime(_formHelper.Model.NewPersianDate);
            if (!gregorian.HasValue)
            {
                ToastService.ShowToastError("تاریخ وارد شده معتبر نیست!");
                _isLoading = false;
                return;
            }

            dateChanged = true;
            hasChanges = true;
        }

        if (!string.IsNullOrEmpty(_formHelper.Model.NewTime) &&
            _formHelper.Model.NewTime != _currentTime)
        {
            if (!TimeSpan.TryParse(_formHelper.Model.NewTime, out var newTime))
            {
                ToastService.ShowToastError("زمان وارد شده معتبر نیست! (فرمت: HH:mm)");
                _isLoading = false;
                return;
            }

            timeChanged = true;
            hasChanges = true;
        }

        if (!hasChanges)
        {
            ToastService.ShowToastInfo("هیچ تغییری اعمال نشده است.");
            _isLoading = false;
            await OnClose();
            return;
        }

        try
        {
            if (dateChanged)
            {
                var newDate = PersianDateHelper.ToGregorianDateTime(_formHelper.Model.NewPersianDate).Value;
                var request = new ChangeOccurrenceDateRequest(
                    oldDate: CurrentDate,
                    newDate: newDate
                );

                var result = await ApiService.SendAsync(
                    () => ApiClient.ChangeOccurrenceDateAsync(TaskId, request),
                    successMessage: null,
                    showErrorToast: false
                );

                if (result?.IsSuccess != true)
                {
                    if (result?.Errors != null)
                    {
                        var errors = string.Join("\n", result.Errors.SelectMany(e => e.Value));
                        ToastService.ShowToastError($"خطا در تغییر تاریخ: {errors}");
                    }
                    else
                    {
                        ToastService.ShowToastError("خطا در تغییر تاریخ");
                    }

                    _isLoading = false;
                    return;
                }
            }

            if (timeChanged)
            {
                var newTime = TimeSpan.Parse(_formHelper.Model.NewTime);
                var request = new ChangeOccurrenceTimeRequest(
                    date: CurrentDate,
                    newTime: newTime
                );

                var result = await ApiService.SendAsync(
                    () => ApiClient.ChangeOccurrenceTimeAsync(TaskId, request),
                    successMessage: null,
                    showErrorToast: false
                );

                if (result?.IsSuccess != true)
                {
                    if (result?.Errors != null)
                    {
                        var errors = string.Join("\n", result.Errors.SelectMany(e => e.Value));
                        ToastService.ShowToastError($"خطا در تغییر زمان: {errors}");
                    }
                    else
                    {
                        ToastService.ShowToastError("خطا در تغییر زمان");
                    }

                    _isLoading = false;
                    return;
                }
            }

            ToastService.ShowToastSuccess("تغییرات با موفقیت اعمال شد!");
            await OnDateTimeChanged.InvokeAsync();
            await OnClose();
        }
        catch (Exception ex)
        {
            ToastService.ShowToastError($"خطا: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnClose()
    {
        await OnCloseRequested.InvokeAsync();
    }

    public class ChangeDateTimeModel
    {
        public string NewPersianDate { get; set; } = "";
        public string NewTime { get; set; } = "";
    }

}