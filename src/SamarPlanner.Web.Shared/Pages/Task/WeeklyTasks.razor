@page "/tasks/weekly"
@attribute [Authorize]
@layout TaskLayout
@inject IApiClient ApiClient
@inject IToastService ToastService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<ModalPortal/>

<div class="weekly-tasks">

    @* ── Header ── *@
    <div class="weekly-header">
        <div class="weekly-header-left">
            <h1 class="weekly-title">هفته‌نامه تسک‌ها</h1>
            <span class="weekly-range">@_weekStart.ToPersianDate() — @_weekEnd.ToPersianDate()</span>
        </div>
        <div class="weekly-nav">
            <button class="weekly-nav-btn" @onclick="() => GoToWeek(-1)" title="هفته قبل">
                <i class="bi bi-chevron-right"></i>
            </button>
            <button class="weekly-nav-btn weekly-nav-today" @onclick="GoToToday" title="این هفته">
                این هفته
            </button>
            <button class="weekly-nav-btn" @onclick="() => GoToWeek(1)" title="هفته بعد">
                <i class="bi bi-chevron-left"></i>
            </button>
        </div>
    </div>

    @{
        @* ── Progress Summary ── *@
        var totalTasks = _groupedTasks.Sum(g => g.Tasks.Count);
        var doneTasks = _groupedTasks.Sum(g => g.Tasks.Count(t =>
            !t.Occurrence.IsSkipped &&
            (t.Occurrence.Status == GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.Done ||
             t.Occurrence.Status == GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.AlmostDone)));
    }
   
    <div class="weekly-summary">
        <div class="weekly-summary-info">
            <span class="weekly-summary-count">
                <span class="weekly-summary-done">@doneTasks</span>
                <span class="weekly-summary-sep">/</span>
                <span>@totalTasks</span>
            </span>
            <span>تسک انجام شده در این هفته</span>
        </div>
        <div class="weekly-summary-track">
            <div class="weekly-summary-fill"
                 style="width: @(totalTasks > 0 ? (doneTasks * 100 / totalTasks) : 0)%">
            </div>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="weekly-loading">
            <div class="weekly-loading-spinner"></div>
            <span>بارگذاری تسک‌ها...</span>
        </div>
    }
    else if (_groupedTasks == null || !_groupedTasks.Any())
    {
        <div class="weekly-empty">
            <div class="weekly-empty-icon">
                <i class="bi bi-calendar3"></i>
            </div>
            <h3>هیچ تسکی در این هفته ندارید</h3>
            <p>تسک‌های شما اینجا نمایش داده می‌شوند.</p>
        </div>
    }
    else
    {
        @* ── Day Columns ── *@
        <div class="weekly-day-list">
            @foreach (var dayGroup in _groupedTasks)
            {
                var isToday = dayGroup.Date.Date == DateTimeOffset.Now.Date;
                var isPast = dayGroup.Date.Date < DateTimeOffset.Now.Date && !isToday;
                var isFuture = dayGroup.Date.Date > DateTimeOffset.Now.Date && !isToday;

                <div
                    class="weekly-day @(isToday ? "weekly-day--today" : "") @(isPast ? "weekly-day--past" : "") @(isFuture ? "weekly-day--future" : "")">
                    <div class="weekly-day-header" @onclick="() => NavigateToDay(dayGroup.Date)">
                        <div class="weekly-day-header-right">
                            <div class="weekly-day-name">@dayGroup.PersianDayName</div>
                            <div class="weekly-day-date">@dayGroup.PersianDate</div>
                        </div>
                        <div class="weekly-day-header-left">
                            @if (dayGroup.Tasks.Any())
                            {
                                var dayDone = dayGroup.Tasks.Count(t =>
                                    !t.Occurrence.IsSkipped &&
                                    (t.Occurrence.Status == GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.Done ||
                                     t.Occurrence.Status == GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.AlmostDone));
                                var dayTotal = dayGroup.Tasks.Count;

                                <div class="weekly-day-progress-mini">
                                    <div class="weekly-day-progress-mini-track">
                                        <div class="weekly-day-progress-mini-fill"
                                             style="width: @(dayTotal > 0 ? (dayDone * 100 / dayTotal) : 0)%">
                                        </div>
                                    </div>
                                    <span class="weekly-day-progress-mini-text">@dayDone/@dayTotal</span>
                                </div>
                            }
                            <span class="weekly-day-badge">@dayGroup.Tasks.Count</span>
                        </div>
                    </div>

                    <div class="weekly-day-tasks">
                        @if (dayGroup.Tasks.Any())
                        {
                            @foreach (var task in dayGroup.Tasks)
                            {
                                <div class="weekly-task-compact">
                                    <button class="weekly-task-status @GetCompactStatusClass(task.Occurrence)"
                                            @onclick:stopPropagation
                                            title="تغییر وضعیت">
                                        @GetCompactStatusIcon(task.Occurrence)
                                    </button>
                                    <div class="weekly-task-body" @onclick:stopPropagation>
                                        <span
                                            class="weekly-task-title @(task.Occurrence.IsSkipped ? "is-skipped" : "")">
                                            @task.Task.Title
                                        </span>
                                        <div class="weekly-task-meta">
                                            @if (task.Occurrence.Time != null)
                                            {
                                                <span class="weekly-task-chip">
                                                    <i class="bi bi-clock"></i>
                                                    @task.Occurrence.Time.Value.ToString(@"hh\:mm")
                                                </span>
                                            }
                                            @if (task.Task.Priority.HasValue)
                                            {
                                                <span
                                                    class="weekly-task-chip weekly-task-chip-@GetPriorityName(task.Task)">
                                                    <i class="bi bi-flag-fill"></i>
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="weekly-day-empty">
                                <i class="bi bi-inbox"></i>
                                <span>بدون تسک</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<DayGroup> _groupedTasks = new();
    private bool _isLoading = true;
    private DateTimeOffset _weekStart;
    private DateTimeOffset _weekEnd;
    private readonly PersianCalendar _persianCalendar = new();

    protected override async Task OnInitializedAsync()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var queryParams = QueryHelpers.ParseQuery(uri.Query);

        if (queryParams.TryGetValue("date", out var dateValue) && !string.IsNullOrEmpty(dateValue))
        {
            var gregorian = PersianDateHelper.ToGregorianDateTime(dateValue!);
            if (gregorian.HasValue)
                SetWeekRange(gregorian.Value);
            else
                SetWeekRange(DateTimeOffset.Now);
        }
        else
        {
            SetWeekRange(DateTimeOffset.Now);
        }

        NavigationManager.LocationChanged += OnLocationChanged;
        await LoadWeekTasks();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        var uri = NavigationManager.ToAbsoluteUri(e.Location);
        var queryParams = QueryHelpers.ParseQuery(uri.Query);

        if (queryParams.TryGetValue("date", out var dateValue) && !string.IsNullOrEmpty(dateValue))
        {
            var gregorian = PersianDateHelper.ToGregorianDateTime(dateValue!);
            if (gregorian.HasValue)
                SetWeekRange(gregorian.Value);
            else
                SetWeekRange(DateTimeOffset.Now);
        }
        else
        {
            SetWeekRange(DateTimeOffset.Now);
        }

        _ = LoadWeekTasks();
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    private void SetWeekRange(DateTimeOffset date)
    {
        var daysSinceSaturday = ((int)date.DayOfWeek - (int)DayOfWeek.Saturday + 7) % 7;
        _weekStart = date.AddDays(-daysSinceSaturday).Date;
        _weekEnd = _weekStart.AddDays(6).Date;
    }

    private void GoToWeek(int direction)
    {
        var newDate = _weekStart.AddDays(direction * 7);
        NavigationManager.NavigateTo($"/tasks/weekly?date={newDate.ToPersianDate()}", forceLoad: false);
    }

    private void GoToToday()
    {
        var today = DateTimeOffset.Now;
        var daysSinceSaturday = ((int)today.DayOfWeek - (int)DayOfWeek.Saturday + 7) % 7;
        var weekStart = today.AddDays(-daysSinceSaturday).Date;
        NavigationManager.NavigateTo($"/tasks/weekly?date={weekStart.ToPersianDate()}", forceLoad: false);
    }

    private void NavigateToDay(DateTimeOffset date)
    {
        NavigationManager.NavigateTo($"/tasks/daily?date={date.ToPersianDate()}", forceLoad: false);
    }


    private async Task LoadWeekTasks()
    {
        try
        {
            _isLoading = true;
            var from = _weekStart.Date;
            var to = _weekEnd.Date;

            var result = await ApiClient.GetTasksWithOccurrencesAsync(from, to);

            if (result.IsSuccess)
            {
                var allTasks = result.Response.Tasks
                    .SelectMany(t => t.Occurrences
                        .Where(o => o.Date.Date >= from && o.Date.Date <= to)
                        .Select(o => new TaskWithOccurrence
                        {
                            Task = t,
                            Occurrence = o
                        })
                    )
                    .ToList();

                _groupedTasks = new List<DayGroup>();
                for (var day = from; day <= to; day = day.AddDays(1))
                {
                    var dayTasks = allTasks
                        .Where(t => t.Occurrence.Date.Date == day)
                        .OrderBy(t => t.Occurrence.IsSkipped)
                        .ThenBy(t =>
                        {
                            return t.Occurrence.Status switch
                            {
                                GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.Done => 3,
                                GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.AlmostDone => 2,
                                GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.NotDone => 1,
                                GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.Pending => 0,
                                _ => 4
                            };
                        })
                        .ThenBy(t => t.Task.Priority.HasValue ? (int)t.Task.Priority.Value : 10)
                        .ThenBy(t => t.Occurrence.Time)
                        .ToList();

                    _groupedTasks.Add(new DayGroup
                    {
                        Date = day,
                        PersianDate = day.ToPersianDate(),
                        PersianDayName = GetWeekday(day),
                        PersianMonth = GetMonthName(day),
                        Tasks = dayTasks
                    });
                }
            }
            else
            {
                _groupedTasks = new List<DayGroup>();
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowToastError($"خطا: {ex.Message}");
            _groupedTasks = new List<DayGroup>();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task RefreshWeek()
    {
        await LoadWeekTasks();
    }

    // ── Compact Status Helpers ──

    private string GetCompactStatusClass(GetTasksWithOccurrencesQueryResultTaskOccurrences occurrence)
    {
        if (occurrence.IsSkipped) return "status-skipped";
        return occurrence.Status switch
        {
            GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.Pending => "status-pending",
            GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.Done => "status-done",
            GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.NotDone => "status-not-done",
            GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.AlmostDone => "status-almost",
            _ => "status-pending"
        };
    }

    private MarkupString GetCompactStatusIcon(GetTasksWithOccurrencesQueryResultTaskOccurrences occurrence)
    {
        if (occurrence.IsSkipped)
            return new MarkupString(@"<svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z'/><circle cx='12' cy='12' r='3'/><line x1='1' y1='1' x2='23' y2='23'/></svg>");

        return occurrence.Status switch
        {
            GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.Pending =>
                new MarkupString(@"<svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='10'/><polyline points='12 6 12 12 16 14'/></svg>"),
            GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.Done =>
                new MarkupString(@"<svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M22 11.08V12a10 10 0 1 1-5.93-9.14'/><polyline points='22 4 12 14.01 9 11.01'/></svg>"),
            GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.NotDone =>
                new MarkupString(@"<svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='10'/><line x1='15' y1='9' x2='9' y2='15'/><line x1='9' y1='9' x2='15' y2='15'/></svg>"),
            GetTasksWithOccurrencesQueryResultTaskOccurrencesStatus.AlmostDone =>
                new MarkupString(@"<svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'/><polyline points='12 8 12 12 14 14'/></svg>"),
            _ =>
                new MarkupString(@"<svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='10'/><polyline points='12 6 12 12 16 14'/></svg>")
        };
    }

    private string GetPriorityName(GetTasksWithOccurrencesQueryResultTasks task)
    {
        return task.Priority switch
        {
            GetTasksWithOccurrencesQueryResultTasksPriority.High => "high",
            GetTasksWithOccurrencesQueryResultTasksPriority.Medium => "medium",
            GetTasksWithOccurrencesQueryResultTasksPriority.Low => "low",
            _ => ""
        };
    }

    private string GetWeekday(DateTimeOffset date)
    {
        var dt = date.DateTime;
        var dayOfWeek = _persianCalendar.GetDayOfWeek(dt);
        return dayOfWeek switch
        {
            DayOfWeek.Saturday => "شنبه",
            DayOfWeek.Sunday => "یکشنبه",
            DayOfWeek.Monday => "دوشنبه",
            DayOfWeek.Tuesday => "سه‌شنبه",
            DayOfWeek.Wednesday => "چهارشنبه",
            DayOfWeek.Thursday => "پنجشنبه",
            DayOfWeek.Friday => "جمعه",
            _ => ""
        };
    }

    private string GetMonthName(DateTimeOffset date)
    {
        var dt = date.DateTime;
        var month = _persianCalendar.GetMonth(dt);
        return month switch
        {
            1 => "فروردین",
            2 => "اردیبهشت",
            3 => "خرداد",
            4 => "تیر",
            5 => "مرداد",
            6 => "شهریور",
            7 => "مهر",
            8 => "آبان",
            9 => "آذر",
            10 => "دی",
            11 => "بهمن",
            12 => "اسفند",
            _ => ""
        };
    }

    private class DayGroup
    {
        public DateTimeOffset Date { get; set; }
        public string PersianDate { get; set; } = "";
        public string PersianDayName { get; set; } = "";
        public string PersianMonth { get; set; } = "";
        public List<TaskWithOccurrence> Tasks { get; set; } = new();
    }

    private class TaskWithOccurrence
    {
        public GetTasksWithOccurrencesQueryResultTasks Task { get; set; } = null!;
        public GetTasksWithOccurrencesQueryResultTaskOccurrences Occurrence { get; set; } = null!;
    }

}