@inherits LayoutComponentBase
@using Blazored.Toast.Configuration

@using SamarPlanner.Web.Shared.Components
@using SamarPlanner.Web.Shared.Services
@inject NavigationManager NavigationManager
@inject ModalService ModalService

<div class="sub-layout">
    @* ── Topbar ── *@
    <ModalPortal />
    <SubTopbar />
    @* $1$ ── Section Header ── #1# *@
    @* <header class="sub-header"> *@
    @*     <nav class="goal-nav-pill"> *@
    @*         <NavLink href="/goals" class="goal-pill-link" ActiveClass="is-active" Match="NavLinkMatch.All"> *@
    @*             <i class="bi bi-bullseye"></i> *@
    @*             <span>اهداف</span> *@
    @*         </NavLink> *@
    @*     </nav> *@
    @* </header> *@

    @* ── Content ── *@
    <main class="sub-content">
        @Body
    </main>

    @* ── FAB ── *@
    <div class="sub-fab">
        <button class="fab-button" @onclick="OpenAddGoalModal" title="هدف جدید">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
        </button>
    </div>
</div>

<BottomNav ActiveSection="goals" />

<BlazoredToasts Position="ToastPosition.TopRight" />
<script src="js/task-dropdown.js"></script>

@code {
    protected override void OnInitialized()
    {
        ModalService.OnChanged += HandleModalChanged;
    }

    private void HandleModalChanged() => InvokeAsync(StateHasChanged);

    private void OpenAddGoalModal()
    {
        ModalService.Show(builder =>
        {
            builder.OpenComponent<AddGoalFormModal>(0);
            builder.AddAttribute(1, nameof(AddGoalFormModal.OnGoalAdded),
                EventCallback.Factory.Create(this, () =>
                {
                    ModalService.Close();
                    NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
                }));
            builder.AddAttribute(2, nameof(AddGoalFormModal.OnCloseRequested),
                EventCallback.Factory.Create(this, () => ModalService.Close()));
            builder.CloseComponent();
        });
    }

    public void Dispose()
    {
        ModalService.OnChanged -= HandleModalChanged;
    }
}