@page "/"
@{
    Layout = "Shared/MainLayout";
}
@model SamarPlanner.Web.Landing.Pages.IndexModel

<div class="index-page">
    <div class="hero-icon">
        <i class="bi bi-calendar2-week"></i>
    </div>
    <h1>به SamarPlanner خوش آمدید</h1>
    <p class="subtitle">برنامه‌ریزی روزانه‌تان را آسان کنید</p>
    <a href="@Model.WebUrl" class="btn btn-login">
        <i class="bi bi-box-arrow-in-right"></i>
        شروع کنید
    </a>
</div>

<script>
    const token = localStorage.getItem("authToken");

    if (token) {
        window.location.replace("@Model.WebUrl");
    }
</script>