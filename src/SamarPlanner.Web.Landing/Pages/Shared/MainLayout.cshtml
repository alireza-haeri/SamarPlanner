<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
    <meta name="description"
          content="ثمر پلنر، ابزار برنامه‌ریزی روزانه و مدیریت اهداف. کارها، اهداف و گزارش‌های خود را به‌سادگی مدیریت کنید."/>
    <meta name="keywords" content="برنامه ریزی روزانه, مدیریت اهداف, تسک منیجر, ثمر پلنر"/>
    <meta name="robots" content="index, follow"/>
    <link rel="canonical" href="https://samarpln.ir/"/>
    <title>ثمر پلنر | برنامه‌ریزی روزانه و مدیریت اهداف</title>
    <base href="/"/>

    <meta property="og:type" content="website"/>
    <meta property="og:title" content="ثمر پلنر | برنامه‌ریزی روزانه"/>
    <meta property="og:description" content="ابزار برنامه‌ریزی روزانه و مدیریت اهداف"/>
    <meta property="og:image" content="https://samarpln.ir/og-image.png"/>
    <meta property="og:url" content="https://samarpln.ir/"/>
    <meta property="og:locale" content="fa_IR"/>
    <meta name="twitter:card" content="summary_large_image"/>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>

    <link rel="icon" type="image/svg+xml" href="favicon.svg"/>

    <link href="/app.css" rel="stylesheet"/>
    <link href="/custom.css" rel="stylesheet"/>
    <link href="/pages-auth.css" rel="stylesheet"/>
    <link href="/MainLayout.css" rel="stylesheet"/>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@300;400;500;600;700;800&display=swap"
          rel="stylesheet">
</head>
<body>
<div id="app">
    <div class="app-container">
        @* ── Header ── *@
        <header class="main-header">
            <div class="header-content">
                <div class="brand-section">
                    <a href="/" class="brand-link">
                        <div class="brand-icon">
                            <i class="bi bi-calendar2-week-fill"></i>
                        </div>
                        <div class="brand-text">
                            <span class="brand-name">SamarPlanner</span>
                            <span class="brand-sub">برنامه‌ریز هوشمند</span>
                        </div>
                    </a>
                </div>
            </div>
        </header>

        @* ── Content ── *@
        <main class="main-content">
            @RenderBody()
        </main>

        @* ── Footer ── *@
        <footer class="footer">
            <div class="container">
                <div class="footer-inner">
                    <div class="footer-right">
                        <span class="footer-brand">
                            <i class="bi bi-calendar2-week-fill"></i>
                            SamarPlanner
                        </span>
                        <span class="footer-sep">·</span>
                        <span class="footer-copy">© ۲۰۲۶</span>
                    </div>
                    <div class="footer-left">
                        <a href="https://github.com/alireza-haeri/SamarPlanner" target="_blank" rel="noopener"
                           class="footer-link">
                            <i class="bi bi-github"></i>
                            <span>مخزن پروژه</span>
                        </a>
                        <span class="footer-sep">·</span>
                        <a href="https://github.com/alireza-haeri" target="_blank" rel="noopener"
                           class="footer-link footer-profile">
                            <img src="https://github.com/alireza-haeri.png" alt="علیرضا حائری" class="footer-avatar"
                                 loading="lazy"/>
                            <span>علیرضا حائری</span>
                        </a>
                        <span class="footer-sep">·</span>
                        <span class="footer-version">v1.0</span>
                    </div>
                </div>
            </div>
        </footer>
    </div>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "SoftwareApplication",
        "name": "SamarPlanner",
        "applicationCategory": "ProductivityApplication",
        "operatingSystem": "Web",
        "description": "ابزار برنامه‌ریزی روزانه و مدیریت اهداف",
        "offers": {
            "@@type": "Offer",
            "price": "0"
        }
    }
</script>
</body>
</html>